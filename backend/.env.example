# Supabase — from supabase.com → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJ...your-anon-key

# OpenAI — for Whisper transcription, GPT-4o vision, LLM fallback
OPENAI_API_KEY=sk-...

# Anthropic — primary LLM (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Apify — TikTok + Instagram scraping
APIFY_API_TOKEN=apify_api_...

# Optional: scheduler config (defaults shown)
# CRON_DAY_OF_WEEK=sun
# CRON_HOUR=2
